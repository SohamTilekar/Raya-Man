[sub_resource type="GDScript" id="GDScript_6ll7h"]
script/source = "extends Camera2D

func _on_main_character_player_moved_pos(pos: Vector2) -> void:
	self.global_position = pos
	var mouse_motion_event := InputEventMouseMotion.new()
	mouse_motion_event.position = get_viewport().get_mouse_position()
	Input.parse_input_event(mouse_motion_event)
"

[sub_resource type="GDScript" id="GDScript_0vfqx"]
script/source = "extends Label

func _process(_delta: float) -> void:
	self.text = str(Engine.get_frames_per_second())
"

[sub_resource type="GDScript" id="GDScript_wbbl4"]
script/source = "extends Label

@onready var tile_size: Vector2 = $\"../../../../Ground\".tile_set.tile_size

func _process(_delta: float) -> void:
	self.text = str(Vector2i($\"../../../../YSorting/Player\".global_position / tile_size))
"

